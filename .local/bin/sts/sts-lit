#!/bin/sh
# Print brightness in percentage

backlight="/sys/class/backlight"

# Find the first backlight
for i in "$backlight"/*/; do
    [ -d "$i" ] && device="$i" && break
done

if [ -n "$device" ]; then
    read -r brightness < "$device/brightness"
    read -r max_brightness < "$device/max_brightness"

    value="$((100 * brightness / max_brightness))"

    case "$value" in
        [0-9])  icon="َ±©ژ" ;;
        1[0-9]) icon="َ±©ڈ" ;;
        2[0-9]) icon="َ±©گ" ;;
        3[0-9]) icon="َ±©گ" ;;
        4[0-9]) icon="َ±©‘" ;;
        5[0-9]) icon="َ±©’" ;;
        6[0-9]) icon="َ±©“" ;;
        7[0-9]) icon="َ±©”" ;;
        8[0-9]) icon="َ±©•" ;;
        9[0-9]) icon="َ±©–" ;;
        100)    icon="َ°›¨" ;;
    esac

    printf '%s %s%%\n' "$icon" "$value"
else
    icon="َ°¹ڈ"
    printf '%s\n' "$icon"
fi
