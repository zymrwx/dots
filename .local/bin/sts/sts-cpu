#!/bin/sh
# Print CPU usage in percentage

cpu1=$(grep '^cpu ' /proc/stat)
sleep 0.01
cpu2=$(grep '^cpu ' /proc/stat)

value=$(printf '%s\n%s\n' "$cpu1" "$cpu2" | awk '
NR==1 {
    u=$2+$4
    t=$2+$4+$5
    next
}
{
    printf "%d\n", ($2+$4-u)/($2+$4+$5-t)*100
}')

printf '%s %s%%\n' "ï’¼" "$value"
