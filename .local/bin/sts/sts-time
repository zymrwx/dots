#!/bin/sh
# Print time and date

value="$(date '+%m-%d %a %H:%M')"

hour="${value##* }"  # Remove date (before space)
hour="${hour%:*}"   # Remove minute (after colon)

case "$hour" in
    01|13) icon="уұҗҝ" ;;
    02|14) icon="уұ‘Җ" ;;
    03|15) icon="уұ‘Ғ" ;;
    04|16) icon="уұ‘Ӯ" ;;
    05|17) icon="уұ‘ғ" ;;
    06|18) icon="уұ‘„" ;;
    07|19) icon="уұ‘…" ;;
    08|20) icon="уұ‘Ҷ" ;;
    09|21) icon="уұ‘Ү" ;;
    10|22) icon="уұ‘Ҳ" ;;
    11|23) icon="уұ‘ү" ;;
    12|00) icon="уұ‘Ҡ" ;;
esac

printf '%s %s\n' "$icon" "$value"
