#!/bin/sh
# Print battery capacity in percentage

if [ -d "/sys/class/power_supply/BAT0" ]; then
    BAT="/sys/class/power_supply/BAT0"
elif [ -d "/sys/class/power_supply/BAT1" ]; then
    BAT="/sys/class/power_supply/BAT1"
else
    # No battery found, show AC adapter icon
    icon="ο΅Π"
    printf '%s\n' "$icon"
    exit 0
fi

read -r value < "$BAT/capacity"
read -r status < "$BAT/status"

case "$status" in
"Discharging")
    case "$value" in
        [0-5])  icon="σΑ²é";;
        [6-9])  icon="σΑ¹Κ";;
        1[0-9]) icon="σΑ¹Μ";;
        2[0-9]) icon="σΑ¹Φ";;
        3[0-9]) icon="σΑ¹Ϋ";;
        4[0-9]) icon="σΑ¹Ϋ";;
        5[0-9]) icon="σΑ¹Ψ";;
        6[0-9]) icon="σΑ¹Ω";;
        7[0-9]) icon="σΑ²Ä";;
        8[0-9]) icon="σΑ²¹";;
        9[0-9]) icon="σΑ²²";;
        100)    icon="σΑ¹Ι";;
    esac
    ;;
"Not charging"|"Full")
    icon="ο΅Π"
    ;;
"Charging")
    icon="νΚΓ"
    ;;
esac

printf '%s %s%%\n' "$icon" "$value"
