#!/bin/sh
# Change network connection's zone

[ -n "$DISPLAY" ] && menu="dmenu -l 9" || menu="fzf"


uuid="$(nmcli connection show | tail -n +2 | $menu | awk '{print $2}')"
[ -z "$uuid" ] && exit 1

zone="$(firewall-cmd --get-zones | tr ' ' '\n' | $menu)"
[ -z "$zone" ] && exit 1

nmcli connection modify "$uuid" connection.zone "$zone"
firewall-cmd --get-active-zones
