#!/bin/sh
# Change network connection's zone

usage() {
    cat <<EOF
USAGE: ${0##*/} [OPTION]

    Print active zones without arguments

OPTIONS:

-h
    print this help message
-s
    set a connection's zone
EOF
    exit 0
}

get_zone() {
    zone="$(firewall-cmd --get-active-zones)"
    printf '%s\n' "$zone"

    if [ -n "$DISPLAY" ]; then
        notify-send "${0##*/}" "$zone"
    fi
}

set_zone() {
    [ -n "$DISPLAY" ] && menu="dmenu -l 9 -p" || menu="fzf --prompt"
    uuid="$(
        nmcli connection show |
        tail -n +2 |
        $menu "connection" |
        awk '{print $2}'
    )"
    [ -z "$uuid" ] && exit 1

    zone="$(
        firewall-cmd --get-zones |
        tr ' ' '\n' |
        $menu "zone"
    )"
    [ -z "$zone" ] && exit 1
    nmcli connection modify "$uuid" connection.zone "$zone"
    firewall-cmd --get-active-zones
}

if [ -z "$1" ]; then
    get_zone
else
    case "$1" in
        -s) set_zone ;;
        *) usage ;;
    esac
fi
