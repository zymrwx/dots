#!/bin/sh
# Toggle touchpad tapping

choice="$(printf "disable\nenable" | dmenu -i -p "${0##*/}")" || exit 0

toggle() {
    for i in $(xinput list | grep -i "touchpad" | grep -oP 'id=\K[0-9]+')
    do
        xinput set-prop "$i" "libinput Tapping Enabled" "$1"
    done
}

case "$choice" in
    disable)
        toggle 0
        ;;
    enable)
        toggle 1
        ;;
esac
