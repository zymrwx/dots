#!/usr/bin/env bash
# Magnifier output
#
# For multiple outputs:
# - Choose where the active window is
# - Fallback to where the cursor is

screenshot="$XDG_RUNTIME_DIR/mag.tmp"
view_cmd=(nsxiv -f --no-bar "$screenshot")

cleanup() { rm -f "$screenshot"; }

capture() {
    local center_x center_y active_window geom

    active_window=$(xdotool getactivewindow 2>/dev/null)

    if [[ -n "$active_window" ]]; then
        geom=$(xdotool getwindowgeometry --shell "$active_window" 2>/dev/null)
        X=$(echo "$geom" | sed -n 's/^X=//p')
        Y=$(echo "$geom" | sed -n 's/^Y=//p')
        WIDTH=$(echo "$geom" | sed -n 's/^WIDTH=//p')
        HEIGHT=$(echo "$geom" | sed -n 's/^HEIGHT=//p')
        center_x=$((X + WIDTH/2))
        center_y=$((Y + HEIGHT/2))
    else
        geom=$(xdotool getmouselocation --shell 2>/dev/null)
        center_x=$(echo "$geom" | sed -n 's/^X=//p')
        center_y=$(echo "$geom" | sed -n 's/^Y=//p')
    fi

    while read -r line; do
        geometry=$(echo "$line" | grep -oE '[0-9]+x[0-9]+\+[0-9]+\+[0-9]+')
        [[ -z "$geometry" ]] && continue

        g_width="${geometry%%x*}"
        rest="${geometry#*x}"
        g_height="${rest%%+*}"
        rest="${rest#*+}"
        g_x="${rest%%+*}"
        g_y="${rest##*+}"

        if (( center_x >= g_x && center_x <= g_x + g_width &&
              center_y >= g_y && center_y <= g_y + g_height )); then
            maim -f png -m 1 -u -g "$geometry" "$screenshot"
            return
        fi
    done < <(xrandr --query | grep " connected")

    maim -f png -m 1 -u "$screenshot"
}

trap cleanup EXIT INT TERM HUP QUIT

if pgrep -f "${view_cmd[*]}" >/dev/null; then
    pkill -f "${view_cmd[*]}"
else
    capture && "${view_cmd[@]}"
fi
