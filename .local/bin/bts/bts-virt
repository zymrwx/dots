#!/bin/sh

sudo sh <<'EOF'
    user="${SUDO_USER:-$USER}"

    usermod -aG libvirt "$user"

    systemctl enable --now libvirtd.socket
    systemctl enable --now virtlogd.socket

    virsh net-define /etc/libvirt/qemu/networks/default.xml
    virsh net-start default
    virsh net-autostart default
EOF
