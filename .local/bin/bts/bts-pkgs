#!/bin/sh

default_cmd="echo"
pkg_cmd="$default_cmd"

usage() {
    cat <<EOF
USAGE: ${0##*/} [--install] [OPTION]...

    Without '-install', only print packages to STDOUT

OPTIONS:

--install
    install packages instead of printing to STDOUT
--base
    add base packages
--extra
    add extra packages
--xorg
    add xorg packages
--dwm-deps
    add DWM stack dependencies
--ime
    add IME
--gui
    add gui tools
--dev
    add dev tools
--all
    add all
EOF
    exit 0
}

add_base() {
    pkg="
        $pkg
        base
        base-devel
        linux
        linux-headers
        linux-firmware
        lvm2
        networkmanager
        vim
        man-db
        bash-completion
        sbctl
        efibootmgr

        archlinux-contrib
        btop
        fzf
        git
        lf
        openbsd-netcat
        openssh
        pacman-contrib
        rsync
        stow
        tree
        firewalld
        udisks2
        pass
    "
}

add_extra() {
    pkg="
        $pkg
        7zip
        android-file-transfer
        android-tools
        bc
        catimg
        cronie
        dictd
        ffmpeg
        ffmpegthumbnailer
        gnome-epub-thumbnailer
        imagemagick
        mediainfo
        cmus
        odt2txt
        perl-image-exiftool
        poppler
        python-mutagen
        qrtool
        task
        tlp
        transmission-cli
        unrar-free
        unzip
        w3m
        wget
        whois
        yt-dlp
        zip
        newsboat
    "
}

add_fonts() {
    pkg="
        $pkg
        adobe-source-code-pro-fonts
        noto-fonts
        noto-fonts-cjk
        noto-fonts-emoji
        ttf-nerd-fonts-symbols
    "

}

add_audio() {
    pkg="
        $pkg
        pipewire
        pipewire-pulse
        pipewire-jack
        wiremix
    "
}


add_themes() {
    pkg="
        $pkg
        gnome-themes-extra
        qt5ct
        qt6ct
    "
}

add_xorg() {
    add_base
    add_fonts
    add_themes

    pkg="
        $pkg
        autorandr
        brightnessctl
        clipmenu
        dunst
        libnotify
        maim
        neovim
        tree-sitter-cli
        picom
        redshift
        slop
        xorg-server
        xorg-xinit
        xorg-xinput
        xorg-xrandr
        xorg-xset
        xorg-xsetroot
        xorg-xev
        xorg-xkill
        xsel
        xss-lock
    "
}

add_dwm_deps() {
    add_xorg
    add_audio

    # nsxiv dependences
    pkg="
        $pkg
        imlib2
        inotify-tools
        libexif
    "
}

add_ime() {
    pkg="
        $pkg
        fcitx5
        fcitx5-chinese-addons
        fcitx5-gtk
    "
}

add_gui() {
    pkg="
        $pkg
        mpv
        qutebrowser
        tesseract-data-eng
        zathura
        zathura-pdf-mupdf

        libvirt
        virt-manager
        qemu-desktop
        dnsmasq
    "
}

add_dev() {
    pkg="
        $pkg
        code

        jdk-openjdk
        openjdk-src
        openjdk-doc
    "
}


add_all() {
    add_base
    add_extra
    add_dwm_deps
    add_ime
    add_gui
    add_dev
}


[ -z "$1" ] && usage

while [ -n "$1" ]; do
    case "$1" in
        --install)
            pkg_cmd="sudo pacman -S --needed"
            ;;
        --base)
            add_base
            ;;
        --extra)
            add_extra
            ;;
        --xorg)
            add_xorg
            ;;
        --dwm-deps)
            add_dwm_deps
            ;;
        --ime)
            add_ime
            ;;
        --gui)
            add_gui
            ;;
        --dev)
            add_dev
            ;;
        --all)
            add_all
            ;;
        *)
            usage
            ;;
    esac
    shift
done

[ -n "$pkg" ] && {
    echo "pkg:"
    $pkg_cmd $pkg
}
