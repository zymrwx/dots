#!/bin/sh

# Thunderbird's client ID
client_id="9e5f94bc-e8a4-4e73-b8be-63364c29d753"
token_dir="$HOME/.local/state/mutt_oauth2"

if [ -z "$1" ]; then
    printf '%s\n' "Missing email address" 1>&2
else
    [ ! -d "$token_dir" ] && mkdir -p "$token_dir"

    /usr/share/neomutt/oauth2/mutt_oauth2.py \
        --verbose \
        --authorize \
        --authflow "authcode" \
        --client-id "$client_id" \
        --provider "microsoft" \
        --email "$1" \
        "$token_dir/$1"
fi

