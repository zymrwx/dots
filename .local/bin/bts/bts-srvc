#!/bin/sh

sudo sh <<'EOF'
    user="${SUDO_USER:-$USER}"

    usermod -aG vboxusers "$user"

    systemctl enable --now NetworkManager.service
    systemctl enable --now systemd-boot-update.service
    systemctl enable --now systemd-timesyncd.service
    systemctl enable --now tlp.service
    systemctl enable --now ufw.service
    systemctl enable --now sshd.service
    systemctl enable --now cronie.service
    systemctl enable --now paccache.timer

    ufw allow from 192.168.0.0/16 to any app SSH
    ufw enable

    [ ! -d /etc/tlp.d ] && mkdir -p /etc/tlp.d
    printf "START_CHARGE_THRESH_BAT0=75\n" > /etc/tlp.d/99-bat.conf
    printf "STOP_CHARGE_THRESH_BAT0=80\n" >> /etc/tlp.d/99-bat.conf
    printf "START_CHARGE_THRESH_BAT1=75\n" >> /etc/tlp.d/99-bat.conf
    printf "STOP_CHARGE_THRESH_BAT1=80\n" >> /etc/tlp.d/99-bat.conf
    tlp start

    [ ! -d /etc/ssh/sshd_config.d ] && mkdir -p /etc/ssh/sshd_config.d
    printf "PasswordAuthentication no\n" >\
        /etc/ssh/sshd_config.d/99-auth.conf

    [ ! -d /etc/systemd/sleep.conf.d ] && mkdir -p /etc/systemd/sleep.conf.d
    printf "[Sleep]\nHibernateMode=shutdown\n" > \
        /etc/systemd/sleep.conf.d/99-hibernate.conf

    [ ! -d /etc/systemd/logind.conf.d ] && mkdir -p /etc/systemd/logind.conf.d
    printf "[Login]\nHandlePowerKey=hibernate\n" > \
        /etc/systemd/logind.conf.d/99-powerkey.conf
EOF
