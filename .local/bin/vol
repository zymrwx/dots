#!/bin/sh
# Change speaker volume

case "$1" in
    -t)
        wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle 2>/dev/null
        ;;
    *)
        wpctl set-volume @DEFAULT_AUDIO_SINK@ "$1" 2>/dev/null
        ;;
esac

value="$(
    wpctl get-volume @DEFAULT_AUDIO_SINK@ |
    awk '{
        vol=$2*100
        printf "%.0f%%", vol
        if($NF=="[MUTED]") printf " [MUTED]"
    }'
)"

pkill -RTMIN+2 dwmblocks
notify-send -u low -h int:value:"${value%%%*}" -t 3000 -r 1003 "${0##*/} $value"
