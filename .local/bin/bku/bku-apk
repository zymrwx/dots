#!/bin/sh
# Backup APKs listed in $HOME/.local/share/env/bku-apk.env via adb

# Path to store APKs
apk_dir="/home/zym/doc/pkg/apk"

# To get a complete installed package list on adroid:
# adb shell pm list packages | cut -d':' -f2-
[ -f "$HOME/.local/share/env/bku-apk.env" ] &&
    . "$HOME/.local/share/env/bku-apk.env"
pkgs="
    $pkgs \
    org.fdroid.fdroid
"

read -p "Continue? (y/n): " choice
if [ "$choice" = "y" ]; then
    [ ! -d "$apk_dir" ] && mkdir -p "$apk_dir"

    for pkg in $pkgs; do
        # path on android
        path="$(adb shell pm path $pkg  | sed 's/^package://')"
        # pkg name without HASH
        name="$(echo $path | sed 's|.*==/\(.*\)==/.*|\1|').apk"

        [ ! -f "${apk_dir}/${name}" ] &&
            adb pull "$path" "${apk_dir}/${name}"

        # Only keep 3 recent versions
        ls -t ${apk_dir}/${pkg}-*.apk | tail -n +4 | xargs -r rm -v --
    done
fi

exit 0
