set adjust-open width

set font 'SourceCodePro normal 13'

set default-bg "#111111"
set completion-bg "#111111"
set completion-highlight-bg "#aaaaaa"
set completion-highlight-fg "#111111"
set index-active-bg "#000000"
set index-active-fg "#ffffff"
set index-bg "#111111"
set index-fg "#aaaaaa"
set inputbar-bg "#111111"
set inputbar-fg "#eeeeee"
set statusbar-bg "#000000"

set statusbar-home-tilde true
set window-title-home-tilde true

set recolor true
set recolor-keephue true
set recolor-reverse-video true
set recolor-darkcolor "#aaaaaa"
set recolor-lightcolor "#111111"

map I recolor

map r reload

map w adjust_window width
map e adjust_window best-fit

map i zoom in
map o zoom out

map < rotate rotate-cw
map > rotate rotate-ccw

map f follow

map b toggle_statusbar
