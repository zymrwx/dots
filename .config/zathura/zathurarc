set adjust-open width

set recolor true

set default-bg "#000000"
set default-fg "#dddddd"
set recolor-lightcolor "#000000"
set recolor-darkcolor "#dddddd"

set statusbar-fg "#000000"
set statusbar-bg "#aaaaaa"

set index-active-bg "#aaaaaa"
set index-active-fg "#000000"
set index-bg "#000000"
set index-fg "#aaaaaa"

set inputbar-bg "#000000"
set font 'SourceCodePro normal 14'

map I recolor

map w adjust_window width
map e adjust_window best-fit

map i zoom in
map o zoom out
map <C-r> rotate rotate-ccw

map f follow

map b toggle_statusbar
