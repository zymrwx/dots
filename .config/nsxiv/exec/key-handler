#!/bin/sh

delete() {
    choice="$(printf "no\nyes" | dmenu -p "rm?" -w "$(xdo id)")" &&
        [ "$choice" = "yes" ] && rm "$file"
}

show_exif() {
    st -t _floating_ sh -c "exiftool \"$file\"  | less -R"
}

rename_img() {
    new_name="$(dmenu -p "rename: " -w "$(xdo id)")"
    dir_name="${file%/*}"
    new_path="$dir_name/$new_name"

    if [ -n "$new_name" ] &&
        [ -e "$new_path" ] &&
        [ "$new_path" != "$file" ];
    then
        choice="$(printf "no\nyes" | dmenu -p "overwrite?" -w "$(xdo id)")" ||
            return 1
        [ "$choice" != "yes" ] && return 1
    fi

    mv -f "$file" "$new_path"

}

scan_qrcode() {
    qrtool decode "$file" | xsel -b &&
        notify-send "nsxiv" "Copied to clipboard"
}

while read file; do
    case "$1" in
        "d") delete ;;
        "e") show_exif ;;
        "r") rename_img ;;
        "s") scan_qrcode ;;
    esac
done
